{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A bookmarked manga for a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who bookmarked this." },
        "mangaId": { "type": "string", "description": "The MangaDex ID of the manga." },
        "title": { "type": "string", "description": "The title of the manga." },
        "coverUrl": { "type": "string", "description": "The cover URL of the manga." },
        "author": { "type": "string", "description": "The author of the manga." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the bookmark was created." }
      },
      "required": ["uid", "mangaId", "title"]
    },
    "ReadingProgress": {
      "title": "Reading Progress",
      "description": "Tracking the user's progress in a manga.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID." },
        "mangaId": { "type": "string", "description": "The MangaDex ID of the manga." },
        "chapterId": { "type": "string", "description": "The last read chapter ID." },
        "chapterNumber": { "type": "string", "description": "The last read chapter number." },
        "pageNumber": { "type": "integer", "description": "The last read page number." },
        "isCompleted": { "type": "boolean", "description": "Whether the chapter is completed." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the progress was last updated." }
      },
      "required": ["uid", "mangaId", "chapterId"]
    },
    "Comic": {
      "title": "Comic",
      "description": "A manga imported from MangaDex.",
      "type": "object",
      "properties": {
        "mangadexId": { "type": "string", "description": "The MangaDex ID." },
        "title": { "type": "string", "description": "The title of the manga." },
        "slug": { "type": "string", "description": "The URL-friendly slug." },
        "description": { "type": "string", "description": "The description." },
        "coverImage": { "type": "string", "description": "The cover image URL." },
        "altTitles": { "type": "array", "items": { "type": "string" }, "description": "Alternative titles." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags/genres." },
        "status": { "type": "string", "description": "Publication status." },
        "contentRating": { "type": "string", "description": "Content rating (safe, suggestive, etc)." },
        "year": { "type": "integer", "description": "Release year." },
        "lastChapterAt": { "type": "string", "format": "date-time", "description": "When the latest chapter was published." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was imported." }
      },
      "required": ["mangadexId", "title", "slug"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A chapter of an imported manga.",
      "type": "object",
      "properties": {
        "mangadexId": { "type": "string", "description": "The MangaDex ID." },
        "comicId": { "type": "string", "description": "The Firestore ID of the parent comic." },
        "chapterNumber": { "type": "string", "description": "The chapter number." },
        "title": { "type": "string", "description": "The chapter title." },
        "pagesCount": { "type": "integer", "description": "Total number of pages." },
        "volumeNumber": { "type": "integer", "description": "The volume number." },
        "language": { "type": "string", "description": "The language code." },
        "publishedAt": { "type": "string", "format": "date-time", "description": "When it was published." },
        "scanStatus": { "type": "string", "description": "Scan status (pending, ready, error)." }
      },
      "required": ["mangadexId", "comicId", "chapterNumber"]
    },
    "Page": {
      "title": "Page",
      "description": "A page of a chapter.",
      "type": "object",
      "properties": {
        "pageNumber": { "type": "integer", "description": "The page number." },
        "originalData": { "type": "string", "description": "JSON string of the original page data." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the page record was created." }
      },
      "required": ["pageNumber", "originalData"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's bookmarked manga."
    },
    "/users/{userId}/progress/{mangaId}": {
      "schema": "ReadingProgress",
      "description": "User's reading progress for specific manga."
    },
    "/comics/{comicId}": {
      "schema": "Comic",
      "description": "Imported comics collection."
    },
    "/comics/{comicId}/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Chapters subcollection for a comic."
    },
    "/comics/{comicId}/chapters/{chapterId}/pages/{pageId}": {
      "schema": "Page",
      "description": "Pages subcollection for a chapter."
    }
  }
}
